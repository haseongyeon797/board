# JWT (필수)
JWT_SECRET=your-secret-here

# OAuth 세션 (없으면 JWT_SECRET 사용)
SESSION_SECRET=

# GitHub OAuth (소셜 로그인)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth App의 Callback URL과 동일해야 함
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# 프론트 주소(쉼표 구분). 비우면 CORS는 개발용으로 모든 Origin 허용
# FRONTEND_ORIGIN=http://127.0.0.1:5500,http://localhost:5173

# GitHub 로그인 후 돌아갈 페이지 = 브라우저에서 index.html 여는 주소와 동일 (예: serve -p 800 → http://localhost:800)
FRONTEND_URL=http://localhost:800

# PostgreSQL (TypeORM)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=board
# 개발 시에만 true (운영에서는 false + 마이그레이션)
DB_SYNCHRONIZE=false
